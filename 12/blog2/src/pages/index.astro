---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../data/site-config.json';

const allPosts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));
const latestPosts = allPosts
  .filter(p => p.frontmatter && p.frontmatter.title)
  .sort((a, b) => new Date(b.frontmatter.date || 0).getTime() - new Date(a.frontmatter.date || 0).getTime())
  .slice(0, 3);
---
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{`${siteConfig.siteName} - أدوات ويب مجانية`}</title>
  <meta name="description" content={siteConfig.siteName + ' - ' + siteConfig.footerDescription}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
  <Header activePage="home" />

  <section class="page-header">
    <div class="header-blur1"></div>
    <div class="header-blur2"></div>
    <div class="container page-header-content">
      <h1>{siteConfig.siteName}</h1>
      <p>{siteConfig.footerDescription}</p>
    </div>
  </section>

  <section class="blog-section">
    <div class="section-header">
      <h2>أحدث المقالات</h2>
      <p>آخر المقالات والأدلة على مدونتنا</p>
    </div>
    <div class="blog-grid" style="max-width:1200px;margin:0 auto">
      {latestPosts.length === 0 && (
        <p style="text-align:center;color:#9ca3af;font-size:1rem;grid-column:1/-1;padding:48px 0">
          لا توجد مقالات بعد. اكتب أول مقال من <a href="/admin" style="color:#6366F1;font-weight:700;">لوحة التحكم</a>.
        </p>
      )}
      {latestPosts.map(post => {
        const { title, description, date, author } = post.frontmatter;
        const formattedDate = date
          ? new Date(date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' })
          : '';
        const authorName = author || 'ToolRar';
        return (
          <article class="blog-card">
            <div class="blog-card-image" style="background:#6366F122">
              <svg viewBox="0 0 24 24" fill="none" stroke="#6366F1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
            </div>
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <span class="blog-card-date">{formattedDate}</span>
              </div>
              <h3 class="blog-card-title"><a href={post.url}>{title}</a></h3>
              <p class="blog-card-excerpt">{description || ''}</p>
              <div class="blog-card-footer">
                <a href={post.url} class="blog-card-link">
                  اقرأ المزيد
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
                <div class="blog-card-author">
                  <div class="blog-card-author-avatar">{authorName.charAt(0)}</div>
                  <span>{authorName}</span>
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
    <div style="text-align:center;margin-top:32px">
      <a href="/blog.html" style="display:inline-flex;align-items:center;gap:8px;padding:12px 28px;border-radius:8px;background:#6366F1;color:#fff;font-weight:700;font-size:0.9rem;border:none;cursor:pointer;text-decoration:none;transition:background 0.2s" onmouseover="this.style.background='#4f46e5'" onmouseout="this.style.background='#6366F1'">
        عرض جميع المقالات
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>

  <Footer />
</body>
</html>
