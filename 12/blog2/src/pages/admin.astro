  // Bulk generation
  window.startBulkGeneration = function() {
    var input = document.getElementById('keywordsInput');
    var lines = input.value.split('\n').filter(function(l) { return l.trim() !== ''; });
    if (lines.length === 0) { showToast('الرجاء إدخال عناوين المقالات', 'error'); return; }
    if (lines.length > 100) { showToast('الحد الأقصى 100 عنوان', 'error'); return; }
    var keywords = lines.map(function(l) { return l.trim(); }).slice(0, 100);
    aiTotalKeywords = keywords.length;
    generatedArticles = {};
    var btn = document.getElementById('startBulkBtn');
    btn.disabled = true;
    btn.textContent = 'جاري التوليد...';
    document.getElementById('publishBar').style.display = 'none';
    document.getElementById('queueList').innerHTML = '';
    document.getElementById('progressFill').style.width = '0%';
    document.getElementById('progressText').innerHTML = '<span class="dot yellow"></span> 0%';
    var queueItems = [];
    keywords.forEach(function(kw) { queueItems.push(addToQueue(kw, 'pending')); });
    var provider = document.getElementById('aiProvider').value;
    var model = document.getElementById('aiModel').value;
    var lang = document.getElementById('aiLang').value;
    var category = document.getElementById('aiCategory').value;
    var externalUrl = document.getElementById('externalUrl').value.trim();
    var anchorText = document.getElementById('anchorText').value.trim();
    var author = document.getElementById('aiAuthor').value;
    var extraPrompt = '';
    if (externalUrl && anchorText) {
      extraPrompt = 'تأكد من إدراج رابط "' + anchorText + '" (الرابط: ' + externalUrl + ') بشكل طبيعي ضمن فقرة مناسبة في المقال. يجب أن يكون الرابط جزءاً طبيعياً من المحتوى.';
    }

    function processNext(index) {
      if (index >= keywords.length) {
        btn.disabled = false;
        btn.textContent = '🚀 بدء التوليد الجماعي';
        var totalDone = Object.keys(generatedArticles).length;
        document.getElementById('publishBar').style.display = 'flex';
        document.getElementById('publishAllBtn').innerHTML = '📰 نشر الكل (' + totalDone + ')';
        showToast('تم الانتهاء من توليد ' + totalDone + ' مقال!', 'success');
        return;
      }
      var batchSize = Math.min(2, keywords.length - index);
      for (var bi = 0; bi < batchSize; bi++) {
        if (queueItems[index + bi]) updateQueueStatus(queueItems[index + bi], 'generating');
      }
      var promises = [];
      for (var pi = 0; pi < batchSize; pi++) {
        var ki = index + pi;
        var kw = keywords[ki];
        (function(idx, kword) {
          promises.push(generateArticleContent(provider, model, kword, lang, extraPrompt).then(function(content) {
            if (!content) { if (queueItems[idx]) updateQueueStatus(queueItems[idx], 'error'); return { error: 'فشل توليد', keyword: kword, index: idx }; }
            var cleaned = cleanAndFormatHtml(content);
            var plain = cleaned.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
            var shortDesc = plain.substring(0, 160);
            generatedArticles[idx] = {
              success: true, keyword: kword, index: idx, id: 'blog_' + Date.now() + '_' + idx,
              title: kword, short_desc: shortDesc, content_preview: plain.substring(0, 200),
              content: cleaned, category: document.getElementById('aiCategory').value, author: document.getElementById('aiAuthor').value, provider: provider, model: model, lang: lang,
              created_at: new Date().toISOString().replace('T', ' ').substring(0, 19)
            };
            if (queueItems[idx]) {
              updateQueueStatus(queueItems[idx], 'done');
              addArticleActions(queueItems[idx], generatedArticles[idx]);
            }
            return { success: true, index: idx };
          }).catch(function(err) {
            if (queueItems[idx]) updateQueueStatus(queueItems[idx], 'error');
            return { error: err.message, keyword: kword, index: idx };
          }));
        })(ki, kw);
      }
      Promise.all(promises).then(function() {
        var progress = Math.round(((index + batchSize) / keywords.length) * 100);
        document.getElementById('progressFill').style.width = progress + '%';
        document.getElementById('progressText').innerHTML = '<span class="dot ' + (progress >= 100 ? 'green' : 'yellow') + '"></span> ' + progress + '%';
        processNext(index + batchSize);
      });
    }

    function addArticleActions(qel, data) {
      var actionsDiv = qel.querySelector('.actions');
      if (!actionsDiv) {
        actionsDiv = document.createElement('div');
        actionsDiv.className = 'actions';
        qel.appendChild(actionsDiv);
      }
      var prevBtn = document.createElement('button');
      prevBtn.className = 'preview-btn';
      prevBtn.textContent = '👁️';
      prevBtn.title = 'معاينة';
      prevBtn.onclick = function() { showAiPreview(data); };
      actionsDiv.appendChild(prevBtn);
    }

    processNext(0);
  };

