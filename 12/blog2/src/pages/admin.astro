  window.autoUploadProject = function() {
    var msg = document.getElementById('uploadProjectMsg');
    if (!projectFiles.length) { showToast('الرجاء اختيار مجلد أولاً', 'error'); return; }
    var token = localStorage.getItem('auto_gh_token') || document.getElementById('autoTokenInput').value;
    var fullName = localStorage.getItem('auto_gh_repo') || '';
    var branch = localStorage.getItem('auto_gh_branch') || 'main';
    if (!token || !fullName) { showToast('الرجاء إعداد GitHub أولاً في تبويب الأتمتة', 'error'); return; }

    var btn = document.getElementById('uploadProjectBtn');
    btn.disabled = true;
    btn.textContent = '⏳ جاري الرفع...';
    document.getElementById('projectUploadProgress').style.display = 'block';
    document.getElementById('projectProgressFill').style.width = '0%';
    document.getElementById('projectProgressText').textContent = '0 / ' + projectFiles.length;
    msg.className = 'msg msg-loading';
    msg.textContent = 'جاري رفع ' + projectFiles.length + ' ملف...';

    var uploaded = 0;
    var errors = 0;
    var skipped = 0;

    function isBinaryFile(path) {
      var ext = path.split('.').pop().toLowerCase();
      return ['png','jpg','jpeg','gif','webp','ico','svg','woff','woff2','ttf','eot','otf','pdf','zip','gz','tar','rar','7z','exe','dll','so','dmg'].indexOf(ext) !== -1;
    }

    function uploadNext(idx) {
      if (idx >= projectFiles.length) {
        btn.disabled = false;
        btn.textContent = '⬆️ رفع إلى GitHub';
        var resultText = '✅ تم رفع ' + uploaded + ' ملف بنجاح!';
        if (skipped > 0) resultText += ' (' + skipped + ' موجود مسبقاً)';
        if (errors > 0) resultText += ' (' + errors + ' أخطاء)';
        msg.className = 'msg msg-' + (errors ? 'error' : 'success');
        msg.textContent = resultText;
        document.getElementById('projectProgressText').textContent = uploaded + ' / ' + projectFiles.length;
        showToast(resultText, errors ? 'error' : 'success');
        return;
      }

      var f = projectFiles[idx];
      var filePath = f.path;
      var apiUrl = 'https://api.github.com/repos/' + encodeURIComponent(fullName) + '/contents/' + encodeURIComponent(filePath);

      var reader = new FileReader();
      reader.onload = function(ev) {
        var base64Content;
        if (isBinaryFile(f.path)) {
          base64Content = ev.target.result.split(',')[1];
        } else {
          base64Content = btoa(unescape(encodeURIComponent(ev.target.result)));
        }

        fetch(apiUrl + '?ref=' + branch, {
          headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json' }
        }).then(function(resp) {
          var existingSha = null;
          if (resp.ok) return resp.json().then(function(d) { existingSha = d.sha; return existingSha; });
          return null;
        }).then(function(sha) {
          var body = {
            message: (sha ? 'تحديث: ' : 'إضافة: ') + filePath,
            content: base64Content,
            branch: branch
          };
          if (sha) body.sha = sha;
          return fetch(apiUrl, {
            method: 'PUT',
            headers: { 'Authorization': 'token ' + token, 'Content-Type': 'application/json', 'Accept': 'application/vnd.github.v3+json' },
            body: JSON.stringify(body)
          });
        }).then(function(r) {
          if (r.status === 422) { skipped++; }
          else if (!r.ok) { errors++; }
          else { uploaded++; }
          var pct = Math.round(((idx + 1) / projectFiles.length) * 100);
          document.getElementById('projectProgressFill').style.width = pct + '%';
          document.getElementById('projectProgressText').textContent = (uploaded + skipped) + ' / ' + projectFiles.length;
          uploadNext(idx + 1);
        }).catch(function() { errors++; uploadNext(idx + 1); });
      };
      if (isBinaryFile(f.path)) reader.readAsDataURL(f.file);
      else reader.readAsText(f.file);
    }
    uploadNext(0);
  };

  window.autoClearSettings = function() {
    ['auto_gh_token','auto_gh_user','auto_gh_repo','auto_gh_branch','auto_cf_token','auto_cf_email','auto_cf_account','auto_cf_project'].forEach(function(k) { localStorage.removeItem(k); });
    autoState = { ghToken: '', ghUser: '', ghRepo: '', ghBranch: 'main', cfToken: '', cfEmail: '', cfAccount: '', cfProject: '' };
    document.getElementById('autoTokenInput').value = '';
    document.getElementById('autoCfToken').value = '';
    document.getElementById('autoCfEmail').value = '';
    document.getElementById('autoGhDetails').style.display = 'none';
    document.getElementById('autoCfDetails').style.display = 'none';
    document.getElementById('autoRepoBrowser').style.display = 'none';
    autoSetStatus('autoGhStatus', 'غير متصل', '#D1D5DB');
    autoSetStatus('autoCfStatus', 'غير متصل', '#D1D5DB');
    autoSetStatus('autoDepStatus', 'غير معروف', '#D1D5DB');
    autoShowMsg('autoGhMsg', 'تم مسح الإعدادات', 'success');
    autoShowMsg('autoCfMsg', 'تم مسح الإعدادات', 'success');
    showToast('🗑️ تم مسح جميع الإعدادات', 'success');
  };

  // Init - add automation setup
  autoLoadState();

  // Init
  renderCategories();
  initAiTab();
  restoreArtAiSettings();
})();
</script>
</body>
</html>
