  // Project upload to GitHub
  var projectFiles = [];

  document.getElementById('projectFolderInput').addEventListener('change', function(e) {
    var files = e.target.files;
    if (!files || !files.length) return;
    projectFiles = [];
    var list = document.getElementById('projectFileList');
    list.innerHTML = '';
    var totalSize = 0;
    for (var i = 0; i < files.length; i++) {
      var f = files[i];
      var path = f.webkitRelativePath || f.name;
      if (path.split('/').some(function(p) { return p.startsWith('.') || p === 'node_modules' || p === '.git'; })) continue;
      projectFiles.push({ name: f.name, path: path, size: f.size, file: f });
      totalSize += f.size;
    }
    document.getElementById('fileCountLabel').textContent = projectFiles.length + ' ملف (' + (totalSize / 1024 / 1024).toFixed(1) + ' MB)';
    document.getElementById('uploadProjectBtn').disabled = false;
    if (projectFiles.length > 0) {
      list.style.display = 'block';
      projectFiles.forEach(function(f, idx) {
        var div = document.createElement('div');
        div.className = 'auto-pf-item';
        var ext = f.path.split('.').pop();
        var icon = ext === 'md' ? '📝' : ext === 'js' || ext === 'ts' ? '⚡' : ext === 'astro' ? '🔥' : ext === 'json' ? '📋' : ext === 'css' ? '🎨' : ext === 'html' ? '🌐' : ext === 'png' || ext === 'jpg' || ext === 'jpeg' || ext === 'gif' || ext === 'webp' || ext === 'svg' || ext === 'ico' ? '🖼️' : ext === 'woff' || ext === 'woff2' || ext === 'ttf' || ext === 'eot' ? '🔤' : ext === 'xml' ? '📄' : ext === 'cjs' || ext === 'mjs' ? '⚡' : '📄';
        div.innerHTML = '<span class="pf-icon">' + icon + '</span><span class="pf-path">' + f.path + '</span><span class="pf-size">' + (f.size / 1024).toFixed(1) + ' KB</span>';
        list.appendChild(div);
      });
    }
  });

