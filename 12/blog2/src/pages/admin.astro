    .arts-table .art-title a{color:#111827;text-decoration:none}
    .arts-table .art-title a:hover{color:#6366F1}
    .arts-table .art-meta{font-size:.72rem;color:#9ca3af;margin-top:2px}
    .arts-table .art-actions{display:flex;gap:4px;flex-wrap:nowrap}
    .arts-table .art-actions button{padding:5px 9px;border-radius:6px;font-size:.7rem;font-weight:600;border:none;cursor:pointer;transition:all .15s;display:inline-flex;align-items:center;gap:3px;font-family:inherit}
    .arts-table .art-actions button svg{width:12px;height:12px}
    .art-status{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:9999px;font-size:.7rem;font-weight:700}
    .art-status-published{background:#d1fae5;color:#065f46}
    .art-status-archived{background:#fef3c7;color:#92400e}
    .arts-empty{text-align:center;padding:64px 0;color:#9ca3af}
    .arts-empty svg{width:48px;height:48px;opacity:.3;margin-bottom:12px}
    .arts-loading{text-align:center;padding:48px 0;color:#6b7280}
    .arts-loading .spinner{display:inline-block;width:24px;height:24px;border:3px solid #E2E8F0;border-top-color:#6366F1;border-radius:50%;animation:spin .6s linear infinite;vertical-align:middle;margin-left:8px}
    @keyframes spin{to{transform:rotate(360deg)}}
    .arts-pagination{display:flex;align-items:center;justify-content:center;gap:8px;margin-top:16px;font-size:.8rem}
    .arts-pagination button{padding:6px 14px;border-radius:6px;font-size:.78rem;font-weight:600;border:none;cursor:pointer;background:#E2E8F0;color:#374151;transition:all .15s;font-family:inherit}
    .arts-pagination button:hover{background:#cbd5e1}
    .arts-pagination button.active{background:#6366F1;color:#fff}
    .arts-pagination button:disabled{opacity:.4;cursor:not-allowed}
    .arts-badge{display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:6px;font-size:.7rem;font-weight:600}
    .arts-badge svg{width:10px;height:10px}
    .guide-step{background:#fff;border:1px solid #E2E8F0;border-radius:14px;padding:20px 24px;margin-bottom:16px}
    .guide-step:last-child{margin-bottom:0}
    .guide-step-num{display:inline-flex;align-items:center;justify-content:center;width:32px;height:32px;background:#6366F1;color:#fff;border-radius:8px;font-size:.85rem;font-weight:800;margin-left:10px}
    .guide-step-title{font-size:1rem;font-weight:700;color:#111827;margin-bottom:8px;display:flex;align-items:center}
    .guide-step p{font-size:.85rem;color:#374151;line-height:1.8;margin-bottom:6px}
    .guide-step code{background:#F1F5F9;padding:2px 8px;border-radius:4px;font-size:.8rem;direction:ltr;display:inline-block;color:#1e293b}
    .guide-step pre{background:#0F172A;color:#E2E8F0;padding:14px 18px;border-radius:10px;font-size:.8rem;line-height:1.7;overflow-x:auto;direction:ltr;text-align:left;margin:8px 0}
    .guide-step .hl{color:#6366F1;font-weight:700}
    .guide-step .tip{background:#EEF2FF;border-right:3px solid #6366F1;padding:10px 14px;border-radius:8px;font-size:.8rem;color:#4338CA;margin:8px 0}
    .guide-step .warn{background:#fef3c7;border-right:3px solid #F59E0B;padding:10px 14px;border-radius:8px;font-size:.8rem;color:#92400e;margin:8px 0}
    .ai-grid-2{display:grid;grid-template-columns:1fr;gap:20px}@media(min-width:992px){.ai-grid-2{grid-template-columns:1fr 1fr}}
    .ai-status{font-size:.78rem;color:#6b7280;display:flex;align-items:center;gap:6px;margin-top:6px}
