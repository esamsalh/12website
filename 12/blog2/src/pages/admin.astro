  window.publishAllArticles = function() {
    var total = Object.keys(generatedArticles).length;
    if (total === 0) { showToast('لا توجد مقالات للنشر', 'error'); return; }
    var cfg = getGhConfig();
    if (!cfg.token || !cfg.user || !cfg.repo) { showToast('يرجى إعداد بيانات GitHub أولاً', 'error'); return; }
    var btn = document.getElementById('publishAllBtn');
    btn.disabled = true;
    btn.textContent = 'جاري النشر...';
    var useEnSlug = document.getElementById('chkEnSlug').checked;
    var useArticleSchema = document.getElementById('chkArticleSchema').checked;
    var useFaqSchema = document.getElementById('chkFaqSchema').checked;
    var useBreadcrumb = document.getElementById('chkBreadcrumb').checked;
    var author = document.getElementById('aiAuthor').value;
    var provider = document.getElementById('aiProvider').value;
    var model = document.getElementById('aiModel').value;
    var basePath = cfg.path;
    var published = 0;
    var errors = 0;
    var errorList = [];
    var keys = Object.keys(generatedArticles).sort(function(a,b) { return parseInt(a) - parseInt(b); });

    function publishNext(idx) {
      if (idx >= keys.length) {
        btn.disabled = false;
        var msg = 'تم نشر ' + published + ' مقال بنجاح!';
        if (errors > 0) msg += ' (' + errors + ' أخطاء)';
        showToast(msg, 'success');
        btn.textContent = '✅ تم النشر (' + published + ')';
        document.getElementById('publishBar').innerHTML = '<span style="color:#10B981;font-weight:700;font-size:.9rem">✅ تم نشر ' + published + ' مقال بنجاح</span>';
        generatedArticles = {};
        return;
      }
      var data = generatedArticles[keys[idx]];
      var title = data.title || data.keyword;
      var slug = slugify(title);
      var cat = data.category || 'general';
      var dateStr = (data.created_at || new Date().toISOString()).substring(0, 10);
      var tags = [cat];

      function doPublish(enSlug) {
        var finalSlug = enSlug || slug;
        var frontmatter = '---\ntitle: "' + title.replace(/"/g, '\\"') + '"\ndescription: "' + (data.short_desc || '').replace(/"/g, '\\"') + '"\ndate: ' + dateStr + '\nauthor: "' + author.replace(/"/g, '\\"') + '"\ncategory: "' + cat.replace(/"/g, '\\"') + '"\ntags: [' + tags.map(function(t) { return '"' + t.replace(/"/g, '\\"') + '"'; }).join(', ') + ']\n---\n\n' + (data.content || '');
        var filePath = basePath + '/' + finalSlug + '.md';
        var contentB64 = btoa(unescape(encodeURIComponent(frontmatter)));
        var ghBody = { message: 'إضافة مقال: ' + title, content: contentB64, branch: cfg.branch };
        return fetch('https://api.github.com/repos/' + encodeURIComponent(cfg.user) + '/' + encodeURIComponent(cfg.repo) + '/contents/' + encodeURIComponent(filePath), {
          method: 'PUT',
          headers: { 'Authorization': 'token ' + cfg.token, 'Content-Type': 'application/json', 'Accept': 'application/vnd.github.v3+json' },
          body: JSON.stringify(ghBody)
        }).then(function(r) {
          if (r.ok) { published++; return true; }
          return r.json().then(function(j) { throw new Error(j.message || 'خطأ في النشر'); });
        });
      }

      if (useEnSlug) {
        generateEnSlug(provider, model, title, data.lang || 'ar').then(function(enSlug) {
          return doPublish(enSlug);
        }).then(function() {
          publishNext(idx + 1);
        }).catch(function(err) {
          errors++;
          errorList.push({ keyword: title, error: err.message });
          publishNext(idx + 1);
        });
      } else {
        doPublish(null).then(function() {
          publishNext(idx + 1);
        }).catch(function(err) {
          errors++;
          errorList.push({ keyword: title, error: err.message });
          publishNext(idx + 1);
        });
      }
    }

    publishNext(0);
  };

