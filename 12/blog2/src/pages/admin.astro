  function callAiApi(provider, model, systemMsg, userMsg, lang, maxTokens) {
    var key = aiApiKeys[provider];
    var endpoint = aiEndpoints[provider];
    if (!key || !endpoint) return Promise.reject('مزود غير مدعوم: ' + provider);
    endpoint = endpoint.replace('{model}', encodeURIComponent(model)).replace('{key}', key);
    var body;
    if (provider === 'google') {
      body = { contents: [{ role: 'user', parts: [{ text: systemMsg + '\n' + userMsg }] }], generationConfig: { maxOutputTokens: maxTokens || 2048, temperature: 0.7 } };
    } else {
      body = { model: model, messages: [{ role: 'system', content: systemMsg }, { role: 'user', content: userMsg }], max_tokens: maxTokens || 2048, temperature: 0.7 };
      if (provider === 'openrouter') body.headers = { 'HTTP-Referer': 'https://toolrar.com', 'X-Title': 'ToolRar Blog' };
    }
    return fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + key },
      body: JSON.stringify(body)
    }).then(function(r) {
      if (!r.ok) return r.text().then(function(t) { throw new Error('HTTP ' + r.status + ': ' + t); });
      return r.json();
    }).then(function(data) {
      if (provider === 'google') {
        var txt = '';
        if (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts) {
          data.candidates[0].content.parts.forEach(function(p) { if (p.text) txt += p.text; });
        }
        return txt;
      }
      return data.choices && data.choices[0] && data.choices[0].message ? data.choices[0].message.content : '';
    });
  }

  function cleanAndFormatHtml(html) {
    if (!html) return '';
    html = html.replace(/^```(?:html)?\s*\n?/gi, '');
    html = html.replace(/\n?```\s*$/gi, '');
    html = html.replace(/(?:\r?\n|^)#{1,4}\s+(.*?)(?:\r?\n|$)/gu, '\n<h2>$1</h2>\n');
    html = html.replace(/\*\*(.*?)\*\*/gs, '<strong>$1</strong>');
    html = html.replace(/__(.*?)__/gs, '<strong>$1</strong>');
    var lines = html.split('\n');
    var inList = false;
    for (var li = 0; li < lines.length; li++) {
      var trimmed = lines[li].trim();
      var m = trimmed.match(/^[-\*]\s+(.*)$/u);
      if (m) {
        if (!inList) { lines[li] = '<ul>\n<li>' + m[1] + '</li>'; inList = true; }
        else { lines[li] = '<li>' + m[1] + '</li>'; }
      } else {
        if (inList && trimmed) { lines[li] = '</ul>\n' + lines[li]; inList = false; }
      }
    }
    if (inList) lines.push('</ul>');
    html = lines.join('\n');
    html = html.replace(/<p>\s*<\/p>/gi, '');
    return html.trim();
  }

  function slugify(str) {
    return str.replace(/[^\w\s\u0600-\u06FF-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-+|-+$/g, '').toLowerCase();
  }

  function generateEnSlug(provider, model, title, lang) {
    var sysMsg = 'You are a URL slug generator. Rules: 1) Extract the core meaning/keywords from the title 2) Generate a short slug (max 5 words, 3-4 is ideal) 3) Use only lowercase English letters and hyphens 4) Remove stop words 5) Be as short as possible. Return ONLY the slug.';
    var userMsg = 'Title: ' + title + '\nSlug:';
    return callAiApi(provider, model, sysMsg, userMsg, 'en', 256).then(function(text) {
      if (!text) { var fallback = slugify(title).replace(/[^\w-]/g,''); if (fallback.length < 3) fallback = 'article-' + Date.now(); return fallback; }
      text = text.trim().replace(/[^\w-]/g, '').replace(/-+/g, '-').replace(/^-+|-+$/g, '');
      var parts = text.split('-').filter(function(p) { return p.length > 0; }).slice(0, 6);
      text = parts.join('-');
      if (text.length < 3) text = slugify(title).replace(/[^\w-]/g,'');
      if (text.length < 3) text = 'article-' + Date.now();
      return text.toLowerCase();
    });
  }

  function generateArticleContent(provider, model, keyword, lang, extraPrompt) {
    var langName = lang === 'ar' ? 'العربية' : 'English';
    var systemMsg = lang === 'ar'
