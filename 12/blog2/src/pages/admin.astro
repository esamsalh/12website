    .queue-item .status.done{background:#d1fae5;color:#065f46}
    .queue-item .status.error{background:#fee2e2;color:#991b1b}
    .progress-bar{height:8px;background:#E2E8F0;border-radius:9999px;overflow:hidden}
    .progress-fill{height:100%;background:#6366F1;border-radius:9999px;transition:width .3s ease}
    .publish-bar{display:none;gap:10px;margin-top:12px;padding-top:12px;border-top:1px solid #E2E8F0;align-items:center;flex-wrap:wrap}
    .preview-btn{background:none;border:none;color:#6366F1;font-size:.7rem;font-weight:600;cursor:pointer;padding:2px 8px;border-radius:4px;transition:all .2s}
    .preview-btn:hover{background:#EEF2FF}
    .ai-opt-check{display:flex;align-items:center;gap:8px;padding:8px 12px;background:#F8FAFC;border:1px solid #E2E8F0;border-radius:8px;cursor:pointer;transition:all .2s}
