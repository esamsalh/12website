    .msg-success{background:#d1fae5;color:#065f46;border:1px solid #a7f3d0;display:block}
    .msg-error{background:#fee2e2;color:#991b1b;border:1px solid #fecaca;display:block}
    .msg-loading{background:#fef3c7;color:#92400e;border:1px solid #fde68a;display:block}
    .slug-preview{font-size:.75rem;color:#6b7280;margin-top:4px;direction:ltr;text-align:right}
    .color-input-wrap{display:flex;align-items:center;gap:10px}
    .color-input-wrap input[type=color]{width:44px;height:40px;border:1px solid #d1d5db;border-radius:6px;padding:2px;cursor:pointer;background:none}
    .color-input-wrap .color-hex{font-size:.82rem;color:#374151;font-weight:600;direction:ltr}
    .cat-list{display:flex;flex-direction:column;gap:8px}
    .cat-item-row{display:flex;align-items:center;gap:12px;padding:12px 16px;background:#F8FAFC;border-radius:10px;border:1px solid #E2E8F0;transition:all .2s}
