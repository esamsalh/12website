  function autoLoadGhDir(container) {
    container.innerHTML = '<div style="padding:12px;text-align:center;color:#6b7280">جاري التحميل...</div>';
    var token = autoState.ghToken;
    var fullName = autoState.ghRepo;
    var branch = autoState.ghBranch;
    if (!token || !fullName) { container.innerHTML = '<div style="padding:12px;color:#EF4444">الرجاء تحديد مستودع أولاً</div>'; return; }
    var path = autoBrowsePath ? '/contents/' + autoBrowsePath : '/contents';
    fetch('https://api.github.com/repos/' + fullName + path + '?ref=' + branch, { headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json' } })
      .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function(items) {
        container.innerHTML = '';
        // Breadcrumb
        var bc = '<div class="auto-breadcrumb">';
        bc += '<span onclick="autoBrowsePath=\'\';autoLoadGhDir(document.getElementById(\'autoRepoBrowser\'))">🏠 /</span>';
        if (autoBrowsePath) {
          var parts = autoBrowsePath.split('/');
          var acc = '';
          parts.forEach(function(p, i) {
            acc += (i > 0 ? '/' : '') + p;
            bc += ' <span>/</span> <span onclick="autoBrowsePath=\'' + acc + '\';autoLoadGhDir(document.getElementById(\'autoRepoBrowser\'))">' + p + '</span>';
          });
        }
        bc += '</div>';
        container.innerHTML = bc;
        if (items.length === 0) { container.innerHTML += '<div style="padding:12px;color:#6b7280">المجلد فارغ</div>'; return; }
        items.forEach(function(item) {
          var div = document.createElement('div');
          div.className = 'auto-gh-file';
          if (item.type === 'dir') {
            div.innerHTML = '<span class="file-icon">📁</span><span class="file-name auto-gh-folder" onclick="autoBrowsePath=\'' + item.path + '\';autoLoadGhDir(document.getElementById(\'autoRepoBrowser\'))">' + item.name + '</span><span style="font-size:.7rem;color:#9ca3aw">مجلد</span>';
          } else {
            var ext = item.name.split('.').pop();
            var icon = ext === 'md' ? '📝' : ext === 'js' || ext === 'ts' || ext === 'astro' ? '⚡' : ext === 'json' ? '📋' : ext === 'css' ? '🎨' : ext === 'html' ? '🌐' : '📄';
            div.innerHTML = '<span class="file-icon">' + icon + '</span><span class="file-name" onclick="autoViewFile(\'' + item.path + '\')">' + item.name + '</span><span style="font-size:.7rem;color:#9ca3af">' + (item.size / 1024).toFixed(1) + ' KB</span>';
          }
          container.appendChild(div);
        });
      })
      .catch(function(err) { container.innerHTML = '<div style="padding:12px;color:#EF4444">❌ ' + err.message + '</div>'; });
  }

  window.autoViewFile = function(path) {
    var token = autoState.ghToken;
    fetch('https://api.github.com/repos/' + autoState.ghRepo + '/contents/' + path + '?ref=' + autoState.ghBranch, { headers: { 'Authorization': 'token ' + token, 'Accept': 'application/vnd.github.v3+json' } })
      .then(function(r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function(data) {
        if (data.content) {
          var content = atob(data.content.replace(/\n/g, ''));
          var lang = path.endsWith('.md') ? 'markdown' : path.endsWith('.js') ? 'javascript' : path.endsWith('.json') ? 'json' : path.endsWith('.astro') ? 'html' : 'text';
          var lines = content.split('\n');
          var preview = lines.slice(0, 50).join('\n');
          showToast('📄 ' + path + ' (' + lines.length + ' سطر)', 'success');
          // Show in modal
          ensurePreviewModal();
          var modal = document.getElementById('aiPreviewTitle');
          if (modal) modal.textContent = '📄 ' + path;
          var body = document.getElementById('aiPreviewBody');
          if (body) body.innerHTML = '<pre style="background:#0F172A;color:#E2E8F0;padding:16px;border-radius:8px;font-size:.75rem;line-height:1.6;overflow-x:auto;max-height:500px;direction:ltr;text-align:left">' + escHtml(preview) + (lines.length > 50 ? '\n\n... (' + (lines.length - 50) + ' سطر إضافي)' : '') + '</pre>';
          var overlay = document.querySelector('.modal-overlay');
          if (overlay) overlay.style.display = 'flex';
        }
      })
      .catch(function(err) { showToast('خطأ: ' + err.message, 'error'); });
  };

