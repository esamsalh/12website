    .img-upload-btn:hover{background:#E2E8F0;border-color:#6366F1;color:#6366F1}
    .img-upload-btn svg{width:18px;height:18px}
    .img-preview-wrap{display:flex;align-items:center;gap:10px;background:#F8FAFC;border-radius:8px;padding:8px 12px;border:1px solid #E2E8F0}
    .img-preview-wrap img{width:48px;height:48px;object-fit:cover;border-radius:6px}
    .img-preview-info{font-size:.75rem;color:#6b7280}
