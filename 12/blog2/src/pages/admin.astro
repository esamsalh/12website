    if (!ps || !ms) return;
    var prov = ps.value;
    var models = aiModelsByProvider[prov] || [];
    ms.innerHTML = '';
    models.forEach(function(m) {
      var opt = document.createElement('option');
      opt.value = m.value;
      opt.textContent = m.text;
      ms.appendChild(opt);
    });
    if (selectedModel) {
      ms.value = selectedModel;
    } else {
      var saved = localStorage.getItem('ai_selected_model_' + prov);
      if (saved && models.some(function(m) { return m.value === saved; })) ms.value = saved;
    }
    localStorage.setItem('ai_selected_provider', prov);
    localStorage.setItem('ai_selected_model_' + prov, ms.value);
  };

