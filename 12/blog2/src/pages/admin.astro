    .editor-tabs{display:flex;gap:0;margin-bottom:12px;border-bottom:1px solid #E2E8F0}
    .editor-tab{background:none;border:none;padding:8px 16px;font-size:.82rem;font-weight:600;color:#6b7280;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;font-family:inherit}
    .editor-tab:hover{color:#374151}
    .editor-tab.active{color:#6366F1;border-bottom-color:#6366F1}
