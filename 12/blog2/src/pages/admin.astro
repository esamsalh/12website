        <div class="arts-mgr-header">
          <div class="arts-mgr-filters">
            <select id="artsFilterStatus"><option value="all">جميع الحالات</option><option value="published">منشور</option><option value="archived">مؤرشف</option></select>
            <select id="artsFilterCategory"><option value="all">جميع الأقسام</option></select>
