  // ====== Articles Management ======
  var artsData = [];
  var artsSortCol = 'date';
  var artsSortDir = -1;

  function parseFrontmatter(md) {
    var result = { frontmatter: {}, content: md };
    var m = md.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
    if (!m) return result;
    result.content = (m[2] || '').trim();
    var lines = m[1].split('\n');
    lines.forEach(function(l) {
      var sep = l.indexOf(': ');
      if (sep < 0) { sep = l.indexOf(':'); }
      if (sep < 0) return;
      var k = l.substring(0, sep).trim();
      var v = l.substring(sep + 1).trim();
      if (v.startsWith('"') && v.endsWith('"')) v = v.slice(1, -1);
      if (v.startsWith('[') && v.endsWith(']')) {
        v = v.slice(1, -1).split(',').map(function(t) { return t.trim().replace(/^"|"$/g, ''); });
      }
      result.frontmatter[k] = v;
    });
    return result;
  }

  function buildFrontmatter(fm) {
    var out = '---\n';
    out += 'title: "' + (fm.title || '').replace(/"/g, '\\"') + '"\n';
    out += 'description: "' + (fm.description || '').replace(/"/g, '\\"') + '"\n';
    out += 'date: ' + (fm.date || new Date().toISOString().split('T')[0]) + '\n';
    out += 'author: "' + (fm.author || 'مدونة ToolRar').replace(/"/g, '\\"') + '"\n';
    if (fm.category) out += 'category: "' + fm.category + '"\n';
    if (fm.tags && fm.tags.length) {
      out += 'tags: [' + fm.tags.map(function(t) { return '"' + t.trim() + '"'; }).join(', ') + ']\n';
    }
    out += '---\n\n';
    return out;
  }

  function ghApi(path, method, body) {
    var cfg = getGhConfig();
    var opts = {
      headers: { 'Authorization': 'token ' + cfg.token, 'Accept': 'application/vnd.github.v3+json' }
    };
    if (body) { opts.method = method || 'PUT'; opts.body = JSON.stringify(body); opts.headers['Content-Type'] = 'application/json'; }
    else { opts.method = method || 'GET'; }
    return fetch('https://api.github.com/repos/' + encodeURIComponent(cfg.user) + '/' + encodeURIComponent(cfg.repo) + path, opts);
  }

  function fetchArticlesFromGitHub() {
    var cfg = getGhConfig();
    if (!cfg.token || !cfg.user || !cfg.repo) {
      document.getElementById('artsListContainer').innerHTML = '<div class="arts-empty"><p style="color:#EF4444">يرجى إعداد بيانات GitHub أولاً في إعدادات النشر</p></div>';
      return Promise.reject('no config');
    }
    document.getElementById('artsListContainer').innerHTML = '<div class="arts-loading"><div class="spinner"></div> جاري تحميل المقالات...</div>';
    var promises = [
      ghApi('/contents/' + cfg.path).then(function(r) {
        if (!r.ok) return [];
        return r.json();
      }).catch(function() { return []; }),
      ghApi('/contents/' + cfg.path + '/_archived').then(function(r) {
        if (!r.ok) return [];
        return r.json();
      }).catch(function() { return []; })
    ];
    return Promise.all(promises).then(function(results) {
      var all = [];
      var seen = {};
      results.forEach(function(files, idx) {
        if (!Array.isArray(files)) return;
        files.forEach(function(f) {
          if (!f.name || !f.name.endsWith('.md') || seen[f.name]) return;
          seen[f.name] = true;
          all.push({ name: f.name, path: f.path, sha: f.sha, archived: idx === 1, _loading: true });
        });
      });
      artsData = all;
      if (all.length === 0) {
        document.getElementById('artsListContainer').innerHTML = '<div class="arts-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg><p>لا توجد مقالات بعد</p></div>';
        document.getElementById('artsCount').textContent = '0 مقال';
        return;
      }
      renderArtsTable();
      return all;
    });
  }

  function renderArtsTable() {
    var statusFilter = document.getElementById('artsFilterStatus').value;
    var catFilter = document.getElementById('artsFilterCategory').value;
    var search = document.getElementById('artsSearchInput').value.trim().toLowerCase();

    var filtered = artsData.filter(function(a) {
      if (a._loading) return true;
      if (statusFilter === 'published' && a.archived) return false;
      if (statusFilter === 'archived' && !a.archived) return false;
      if (catFilter !== 'all' && a.fm && a.fm.category !== catFilter) return false;
      if (search && a.fm && a.fm.title && a.fm.title.toLowerCase().indexOf(search) === -1 && a.name.toLowerCase().indexOf(search) === -1) return false;
      return true;
    });

    filtered.sort(function(a, b) {
      if (!a.fm || !b.fm) return 0;
      var va, vb;
      if (artsSortCol === 'title') { va = (a.fm.title || '').toLowerCase(); vb = (b.fm.title || '').toLowerCase(); }
      else if (artsSortCol === 'category') { va = (a.fm.category || ''); vb = (b.fm.category || ''); }
      else { va = a.fm.date || ''; vb = b.fm.date || ''; }
      if (va < vb) return -1 * artsSortDir;
      if (va > vb) return 1 * artsSortDir;
      return 0;
    });

    document.getElementById('artsCount').textContent = filtered.length + ' مقال' + (filtered.length !== artsData.length ? ' (من أصل ' + artsData.length + ')' : '');

    if (filtered.length === 0) {
      document.getElementById('artsListContainer').innerHTML = '<div class="arts-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg><p>لا توجد مقالات مطابقة</p></div>';
      return;
    }

    var html = '<table class="arts-table"><thead><tr>';
    html += '<th onclick="sortArts(\'title\')">العنوان <span class="sort-arrow' + (artsSortCol === 'title' ? ' active' : '') + '">' + (artsSortCol === 'title' ? (artsSortDir === 1 ? '▲' : '▼') : '▽') + '</span></th>';
    html += '<th onclick="sortArts(\'category\')">القسم <span class="sort-arrow' + (artsSortCol === 'category' ? ' active' : '') + '">' + (artsSortCol === 'category' ? (artsSortDir === 1 ? '▲' : '▼') : '▽') + '</span></th>';
    html += '<th onclick="sortArts(\'date\')">التاريخ <span class="sort-arrow' + (artsSortCol === 'date' ? ' active' : '') + '">' + (artsSortCol === 'date' ? (artsSortDir === 1 ? '▲' : '▼') : '▽') + '</span></th>';
    html += '<th>الحالة</th><th>الإجراءات</th></tr></thead><tbody>';

    filtered.forEach(function(a) {
      if (a._loading) {
        html += '<tr><td colspan="5"><div class="arts-loading" style="padding:12px"><div class="spinner"></div> جاري التحميل...</div></td></tr>';
        return;
      }
      var fm = a.fm || {};
      var title = fm.title || a.name.replace('.md', '');
      var cat = fm.category || '';
      var date = fm.date || '';
      var formattedDate = date ? new Date(date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'short', day: 'numeric' }) : '-';
      var slug = a.name.replace('.md', '');
      var blogUrl = '/blog/' + slug + '.html';
      var isArchived = a.archived;

      html += '<tr>';
      html += '<td><div class="art-title"><a href="' + blogUrl + '" target="_blank" title="' + escHtml(title) + '">' + escHtml(title) + '</a></div><div class="art-meta">' + escHtml(slug) + '</div></td>';
      html += '<td>' + escHtml(cat) + '</td>';
      html += '<td style="white-space:nowrap">' + formattedDate + '</td>';
      html += '<td><span class="art-status ' + (isArchived ? 'art-status-archived' : 'art-status-published') + '">' + (isArchived ? 'مؤرشف' : 'منشور') + '</span></td>';
      html += '<td><div class="art-actions">';
      html += '<button onclick="editArticle(\'' + a.sha + '\',\'' + a.path.replace(/\\/g, '\\\\').replace(/'/g, "\\'") + '\')" style="background:#EEF2FF;color:#6366F1" title="تعديل"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg> تعديل</button>';
      html += '<button onclick="window.open(\'' + blogUrl + '\',\'_blank\')" style="background:#F1F5F9;color:#475569" title="عرض"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg></button>';
      if (isArchived) {
        html += '<button onclick="unarchiveArticle(\'' + a.sha + '\',\'' + a.path.replace(/\\/g, '\\\\').replace(/'/g, "\\'") + '\',\'' + a.name.replace(/'/g, "\\'") + '\')" style="background:#d1fae5;color:#065f46" title="نشر"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> نشر</button>';
      } else {
        html += '<button onclick="archiveArticle(\'' + a.sha + '\',\'' + a.path.replace(/\\/g, '\\\\').replace(/'/g, "\\'") + '\',\'' + a.name.replace(/'/g, "\\'") + '\')" style="background:#fef3c7;color:#92400e" title="أرشفة"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg> أرشفة</button>';
      }
      html += '<button onclick="deleteArticle(\'' + a.sha + '\',\'' + a.path.replace(/\\/g, '\\\\').replace(/'/g, "\\'") + '\',\'' + a.name.replace(/'/g, "\\'") + '\')" style="background:#fef2f2;color:#dc2626" title="حذف"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>';
      html += '</div></td>';
      html += '</tr>';
    });

    html += '</tbody></table>';
    document.getElementById('artsListContainer').innerHTML = html;
  }

  window.sortArts = function(col) {
    if (artsSortCol === col) artsSortDir *= -1;
    else { artsSortCol = col; artsSortDir = -1; }
    renderArtsTable();
  };

  function loadArticleContent(sha, path) {
    return ghApi('/contents/' + path).then(function(r) {
      if (!r.ok) throw new Error('فشل تحميل المقال');
      return r.json();
    }).then(function(data) {
      var decoded = atob(data.content.replace(/\n/g, ''));
      var parsed = parseFrontmatter(decoded);
      var fm = parsed.frontmatter;
      return {
        sha: data.sha,
        path: data.path,
        name: data.name.replace('.md', ''),
        decoded: decoded,
        fm: fm,
        content: parsed.content
      };
    });
  }

  window.editArticle = function(sha, path) {
    var msg = document.getElementById('artsListContainer').querySelector('.arts-loading, .arts-empty');
    loadArticleContent(sha, path).then(function(article) {
      var fm = article.fm;
      document.getElementById('titleInput').value = fm.title || '';
      var slug = article.name;
      document.getElementById('slugInput').value = slug;
      document.getElementById('slugPreview').textContent = 'blog/' + slug + '.md';
      document.getElementById('descInput').value = fm.description || '';
      document.getElementById('dateInput').value = fm.date || new Date().toISOString().split('T')[0];
      document.getElementById('contentInput').value = article.content || '';
      document.getElementById('tagsInput').value = (fm.tags || []).join(', ');
      if (fm.category) document.getElementById('categorySelect').value = fm.category;
      sessionStorage.setItem('edit_sha', article.sha);
      sessionStorage.setItem('edit_path', article.path);
      sessionStorage.setItem('edit_name', article.name);
      document.getElementById('publishBtn').textContent = 'تحديث المقال على GitHub';
      switchTab('articles');
      showMsg(document.getElementById('publishMsg'), 'تم تحميل المقال للتعديل. قم بإجراء التغييرات ثم اضغط "تحديث المقال"', 'loading');
    }).catch(function(err) {
      alert('خطأ: ' + err.message);
    });
  };

  window.deleteArticle = function(sha, path, name) {
    if (!confirm('هل أنت متأكد من حذف "' + name.replace('.md', '') + '"؟\n\nهذا الإجراء لا يمكن التراجع عنه!')) return;
    if (!confirm('تأكيد الحذف النهائي للمقال؟')) return;
    var msg = document.getElementById('artsListContainer');
    ghApi('/contents/' + path, 'DELETE', { message: 'حذف مقال: ' + name, sha: sha, branch: getGhConfig().branch })
      .then(function(r) {
        if (!r.ok) return r.json().then(function(e) { throw new Error(e.message || 'خطأ ' + r.status); });
        showMsg(document.getElementById('publishMsg'), 'تم حذف المقال بنجاح', 'success');
        fetchArticlesFromGitHub();
      }).catch(function(err) {
        alert('خطأ في الحذف: ' + err.message);
        fetchArticlesFromGitHub();
      });
  };

  window.archiveArticle = function(sha, path, name) {
    if (!confirm('هل تريد أرشفة "' + name.replace('.md', '') + '"؟\n\nالمقال المؤرشف لا يظهر للزوار ولا لمحركات البحث.')) return;
    var cfg = getGhConfig();
    var archivedPath = cfg.path + '/_archived/' + name;
    ghApi('/contents/' + path).then(function(r) {
      if (!r.ok) throw new Error('فشل تحميل المقال');
      return r.json();
    }).then(function(data) {
      var content = data.content;
      return ghApi('/contents/' + archivedPath, 'PUT', { message: 'أرشفة مقال: ' + name, content: content, branch: cfg.branch });
    }).then(function(r) {
      if (!r.ok) return r.json().then(function(e) { throw new Error(e.message || 'خطأ في الأرشفة'); });
      return ghApi('/contents/' + path, 'DELETE', { message: 'نقل مقال إلى الأرشيف: ' + name, sha: sha, branch: cfg.branch });
    }).then(function(r) {
      if (!r.ok) return r.json().then(function(e) { throw new Error(e.message || 'خطأ في حذف المقال القديم'); });
      showMsg(document.getElementById('publishMsg'), 'تم أرشفة المقال بنجاح', 'success');
      fetchArticlesFromGitHub();
    }).catch(function(err) {
      alert('خطأ: ' + err.message);
      fetchArticlesFromGitHub();
    });
  };

  window.unarchiveArticle = function(sha, path, name) {
    if (!confirm('هل تريد إعادة نشر "' + name.replace('.md', '') + '"؟')) return;
    var cfg = getGhConfig();
    var blogPath = cfg.path + '/' + name;
    ghApi('/contents/' + path).then(function(r) {
      if (!r.ok) throw new Error('فشل تحميل المقال');
      return r.json();
    }).then(function(data) {
      return ghApi('/contents/' + blogPath, 'PUT', { message: 'إعادة نشر مقال من الأرشيف: ' + name, content: data.content, branch: cfg.branch });
    }).then(function(r) {
      if (!r.ok) return r.json().then(function(e) { throw new Error(e.message || 'خطأ في إعادة النشر'); });
      return ghApi('/contents/' + path, 'DELETE', { message: 'حذف المقال من الأرشيف: ' + name, sha: sha, branch: cfg.branch });
    }).then(function(r) {
      if (!r.ok) return r.json().then(function(e) { throw new Error(e.message || 'خطأ في حذف النسخة المؤرشفة'); });
      showMsg(document.getElementById('publishMsg'), 'تم إعادة نشر المقال بنجاح', 'success');
      fetchArticlesFromGitHub();
    }).catch(function(err) {
      alert('خطأ: ' + err.message);
      fetchArticlesFromGitHub();
    });
  };

  // Wire up filter/search events
  document.getElementById('artsFilterStatus').addEventListener('change', renderArtsTable);
  document.getElementById('artsFilterCategory').addEventListener('change', renderArtsTable);
  document.getElementById('artsSearchInput').addEventListener('input', renderArtsTable);
  document.getElementById('artsRefreshBtn').addEventListener('click', function() { fetchArticlesFromGitHub(); });

  // Load articles when switching to manage tab
  var origSwitchTab = window.switchTab;
  window.switchTab = function(tabId) {
    origSwitchTab(tabId);
    if (tabId === 'manage-articles') {
      var cfg = getGhConfig();
      if (!cfg.token || !cfg.user || !cfg.repo) {
        document.getElementById('artsListContainer').innerHTML = '<div class="arts-empty"><p style="color:#EF4444">يرجى إعداد بيانات GitHub أولاً في إعدادات النشر</p></div>';
      } else {
        fetchArticlesFromGitHub().then(function() {
          // Load full content for each article
          var loadPromises = artsData.map(function(a) {
            if (a._loading) {
              return loadArticleContent(a.sha, a.path).then(function(art) {
                a.fm = art.fm;
                a._loading = false;
              }).catch(function() {
                a.fm = {};
                a._loading = false;
              });
            }
            return Promise.resolve();
          });
          return Promise.all(loadPromises);
        }).then(function() {
          renderArtsTable();
          // Update category filter
          var sel = document.getElementById('artsFilterCategory');
          var cats = {};
          artsData.forEach(function(a) {
            if (a.fm && a.fm.category) cats[a.fm.category] = true;
          });
          var current = sel.value;
          sel.innerHTML = '<option value="all">جميع الأقسام</option>';
          Object.keys(cats).sort().forEach(function(c) { sel.innerHTML += '<option value="' + escHtml(c) + '">' + escHtml(c) + '</option>'; });
          if (current) sel.value = current;
        });
      }
    }
  };

  // Logout
  document.getElementById('logoutBtn').addEventListener('click', function() {
    if (!confirm('هل أنت متأكد من تسجيل الخروج؟')) return;
    localStorage.removeItem('gh_token');
    localStorage.removeItem('gh_user');
    localStorage.removeItem('gh_repo');
    localStorage.removeItem('gh_branch');
    localStorage.removeItem('gh_path');
    window.location.href = '/blog.html';
  });

  // Init
  renderCategories();
})();
</script>
</body>
</html>
