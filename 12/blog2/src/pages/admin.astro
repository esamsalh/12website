    .arts-mgr-filters{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
    .arts-mgr-filters select,.arts-mgr-filters input{padding:7px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:.8rem;font-family:inherit;background:#fff;color:#1e293b}
    .arts-mgr-filters select:focus,.arts-mgr-filters input:focus{outline:none;border-color:#6366F1}
    .arts-table{width:100%;border-collapse:collapse;font-size:.82rem}
    .arts-table th{text-align:right;padding:12px 14px;font-weight:700;color:#6b7280;border-bottom:2px solid #E2E8F0;white-space:nowrap;cursor:pointer;user-select:none}
    .arts-table th:hover{color:#6366F1}
