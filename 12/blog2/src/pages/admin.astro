    .cat-item-slug{font-size:.72rem;color:#6b7280;direction:ltr;text-align:right}
    .cat-item-actions{display:flex;gap:6px;flex-shrink:0}
    .editor-layout{display:grid;grid-template-columns:1fr;gap:20px}
    @media(min-width:992px){.editor-layout{grid-template-columns:1fr 1fr}}
    .editor-preview{background:#fff;border:1px solid #E2E8F0;border-radius:14px;padding:24px;min-height:400px;overflow-y:auto;max-height:70vh}
    .editor-preview h2{font-size:1.2rem;font-weight:800;color:#111827;margin-bottom:10px;padding-bottom:6px;border-bottom:2px solid #6366F1}
