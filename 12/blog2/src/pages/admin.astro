  </div>

  <footer style="text-align:center;padding:16px;border-top:1px solid #E2E8F0;background:#fff;font-size:.75rem;color:#9ca3af">ToolRar &copy; 2026 جميع الحقوق محفوظة</footer>
</div>

<script>
(function() {
  'use strict';

  var defaultCategories = [
    { id: 'text-tools', name: 'أدوات النصوص والكلمات', color: '#6366F1', icon: '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>', desc: 'أدوات تحرير النصوص وتحليل الكلمات' },
    { id: 'developer', name: 'أدوات المطورين', color: '#10B981', icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>', desc: 'أدوات البرمجة وتطوير الويب' },
    { id: 'photo-editing', name: 'أدوات الصور والتصميم', color: '#F59E0B', icon: '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>', desc: 'أدوات تحرير الصور والتصميم الجرافيكي' },
    { id: 'calculators', name: 'أدوات الحاسبة', color: '#3B82F6', icon: '<rect width="20" height="20" x="2" y="2" rx="2"/><path d="M6 12h4"/><path d="M8 10v4"/><path d="M15 13h.01"/><path d="M18 11h.01"/>', desc: 'حاسبات رياضية ومالية' },
    { id: 'docs-tools', name: 'أدوات PDF', color: '#EC4899', icon: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>', desc: 'أدوات تحرير ودمج PDF' },
    { id: 'zip-tools', name: 'أدوات ZIP والضغط', color: '#059669', icon: '<path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/>', desc: 'أدوات ضغط وفك ضغط الملفات' },
    { id: 'seo', name: 'أدوات SEO', color: '#14B8A6', icon: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m9 8 5 3-5 3V8z"/>', desc: 'أدوات تحسين محركات البحث' },
    { id: 'general', name: 'أدوات متنوعة', color: '#F59E0B', icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>', desc: 'أدوات عامة متنوعة' },
    { id: 'social-media', name: 'أدوات سوشيال ميديا', color: '#8B5CF6', icon: '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>', desc: 'أدوات إدارة السوشيال ميديا' }
  ];

  var categories = loadCategories();
  var uploadedImage = null;

  function loadCategories() {
    try {
      var d = localStorage.getItem('toolrar_categories');
      if (d) return JSON.parse(d);
    } catch(e) {}
    return defaultCategories;
  }

  function saveCategories() {
    localStorage.setItem('toolrar_categories', JSON.stringify(categories));
  }

  function renderCategories() {
    var list = document.getElementById('categoriesList');
    if (!categories.length) {
      list.innerHTML = '<div class="empty-state"><p>لا توجد أقسام بعد. أضف أول قسم الآن.</p></div>';
      return;
    }
    var html = '<div class="cat-list">';
    categories.forEach(function(c, i) {
      html += '<div class="cat-item-row">';
      html += '<div class="cat-item-color" style="background:' + c.color + '"></div>';
      html += '<div class="cat-item-info"><div class="cat-item-name"><span class="color-swatch" style="background:' + c.color + '"></span>' + escHtml(c.name) + '</div><div class="cat-item-slug">' + escHtml(c.id) + '</div></div>';
      html += '<div class="cat-item-actions">';
      html += '<button class="btn btn-secondary btn-sm" onclick="editCategory(' + i + ')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.12 2.12 0 0 1 3 3L12 15l-4 1 1-4Z"/></svg></button>';
      html += '<button class="btn btn-danger btn-sm" onclick="deleteCategory(' + i + ')"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>';
      html += '</div></div>';
    });
    html += '</div>';
    list.innerHTML = html;
    updateCategorySelect();
    updateStats();
  }

  function updateCategorySelect() {
    var sel = document.getElementById('categorySelect');
    if (!sel) return;
    sel.innerHTML = '<option value="">اختر القسم...</option>';
    categories.forEach(function(c) {
      sel.innerHTML += '<option value="' + escHtml(c.id) + '">' + escHtml(c.name) + '</option>';
    });
  }

  window.editCategory = function(index) {
    var c = categories[index];
    document.getElementById('catNameInput').value = c.name;
    document.getElementById('catSlugInput').value = c.id;
    document.getElementById('catColorInput').value = c.color;
    document.getElementById('catColorHex').textContent = c.color;
    document.getElementById('catDescInput').value = c.desc || '';
    document.getElementById('catIconInput').value = c.icon || '';
    document.getElementById('catOrderInput').value = (index + 1).toString();
    document.getElementById('catEditId').value = index;
    document.getElementById('saveCategoryBtn').textContent = 'تحديث القسم';
    document.getElementById('cancelCategoryBtn').style.display = 'inline-flex';
    document.getElementById('cancelCategoryBtn').onclick = resetCategoryForm;
    document.getElementById('catMsg').className = 'msg';
    document.getElementById('catMsg').textContent = '';
    document.getElementById('catNameInput').focus();
  };

  window.deleteCategory = function(index) {
    if (!confirm('هل أنت متأكد من حذف القسم "' + categories[index].name + '"؟')) return;
    categories.splice(index, 1);
    saveCategories();
    renderCategories();
  };

  function resetCategoryForm() {
    document.getElementById('catNameInput').value = '';
    document.getElementById('catSlugInput').value = '';
    document.getElementById('catColorInput').value = '#6366F1';
    document.getElementById('catColorHex').textContent = '#6366F1';
    document.getElementById('catDescInput').value = '';
    document.getElementById('catIconInput').value = '';
    document.getElementById('catOrderInput').value = '1';
    document.getElementById('catEditId').value = '';
    document.getElementById('saveCategoryBtn').textContent = 'حفظ القسم';
    document.getElementById('cancelCategoryBtn').style.display = 'none';
    document.getElementById('catMsg').className = 'msg';
    document.getElementById('catMsg').textContent = '';
  }

  document.getElementById('catColorInput').addEventListener('input', function() {
    document.getElementById('catColorHex').textContent = this.value;
  });

  document.getElementById('saveCategoryBtn').addEventListener('click', function() {
    var name = document.getElementById('catNameInput').value.trim();
    var slug = document.getElementById('catSlugInput').value.trim();
    var color = document.getElementById('catColorInput').value;
    var desc = document.getElementById('catDescInput').value.trim();
    var icon = document.getElementById('catIconInput').value.trim();
    var editId = document.getElementById('catEditId').value;
    var msg = document.getElementById('catMsg');

    if (!name || !slug) { msg.className = 'msg msg-error'; msg.textContent = 'يرجى إدخال اسم القسم والـ slug'; return; }

    if (editId !== '') {
      categories[parseInt(editId)] = { id: slug, name: name, color: color, icon: icon, desc: desc };
    } else {
      if (categories.some(function(c) { return c.id === slug; })) {
        msg.className = 'msg msg-error'; msg.textContent = 'يوجد قسم بنفس الـ slug بالفعل'; return;
      }
      categories.push({ id: slug, name: name, color: color, icon: icon, desc: desc });
    }
    saveCategories();
    renderCategories();
    resetCategoryForm();
    msg.className = 'msg msg-success'; msg.textContent = 'تم حفظ القسم بنجاح';
  });

  // Tab switching
  var tabs = document.querySelectorAll('.admin-tab');
  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      switchTab(this.getAttribute('data-tab'));
    });
  });

  window.switchTab = function(tabId) {
    tabs.forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.tab-content').forEach(function(tc) { tc.classList.remove('active'); });
    document.querySelector('.admin-tab[data-tab="' + tabId + '"]').classList.add('active');
    document.getElementById('tab' + tabId.charAt(0).toUpperCase() + tabId.slice(1)).classList.add('active');
  };

  // Editor mode tabs (write/preview)
  document.querySelectorAll('#editorModeTabs .editor-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      document.querySelectorAll('#editorModeTabs .editor-tab').forEach(function(t) { t.classList.remove('active'); });
      this.classList.add('active');
      if (this.getAttribute('data-mode') === 'preview') updatePreview();
    });
  });

  function escHtml(s) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function simpleMarkdown(md) {
    if (!md) return '<div class="empty-state"><p>ابدأ بكتابة المحتوى لرؤية المعاينة</p></div>';
    var h = md
      .replace(/^### (.+)$/gm, '<h3>$1</h3>')
      .replace(/^## (.+)$/gm, '<h2>$1</h2>')
      .replace(/^# (.+)$/gm, '<h2>$1</h2>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/^> (.+)$/gm, '<blockquote>$1</blockquote>')
      .replace(/!\[(.+?)\]\((.+?)\)/g, '<img src="$2" alt="$1" loading="lazy">')
      .replace(/\[(.+?)\]\((.+?)\)/g, '<a href="$2" target="_blank">$1</a>')
      .replace(/^- (.+)$/gm, '<li>$1</li>')
      .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
      .replace(/^\d+\. (.+)$/gm, '<li>$1</li>')
      .replace(/(?:^<li>.*<\/li>\n?)+/g, function(m) { return '<ol>' + m + '</ol>'; })
      .replace(/\n\n/g, '</p><p>')
      .replace(/\n/g, '<br>');
    return '<p>' + h + '</p>';
  }

