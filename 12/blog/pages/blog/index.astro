---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import siteConfig from '../../data/site-config.json';

const allPosts = Object.values(import.meta.glob('./*.md', { eager: true }));
const posts = allPosts
  .filter(p => p.frontmatter && p.frontmatter.title)
  .sort((a, b) => new Date(b.frontmatter.date || 0).getTime() - new Date(a.frontmatter.date || 0).getTime());

const categoryColors = {
  'text-tools': '#6366F1',
  'developer': '#10B981',
  'photo-editing': '#F59E0B',
  'calculators': '#3B82F6',
  'docs-tools': '#EC4899',
  'zip-tools': '#059669',
  'seo': '#14B8A6',
  'general': '#F59E0B',
  'social-media': '#8B5CF6',
};

const categoryIcons = {
  'text-tools': '<polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/>',
  'developer': '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  'photo-editing': '<rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>',
  'calculators': '<rect width="20" height="20" x="2" y="2" rx="2"/><path d="M6 12h4"/><path d="M8 10v4"/><path d="M15 13h.01"/><path d="M18 11h.01"/>',
  'docs-tools': '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>',
  'zip-tools': '<path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/>',
  'seo': '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="m9 8 5 3-5 3V8z"/>',
  'general': '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
  'social-media': '<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>',
};

const categoryNames = {
  'text-tools': 'أدوات النصوص والكلمات',
  'developer': 'أدوات المطورين',
  'photo-editing': 'أدوات الصور والتصميم',
  'calculators': 'أدوات الحاسبة',
  'docs-tools': 'أدوات PDF',
  'zip-tools': 'أدوات ZIP والضغط',
  'seo': 'أدوات SEO',
  'general': 'أدوات متنوعة',
  'social-media': 'أدوات سوشيال ميديا',
};

const grouped = {};
for (const post of posts) {
  const cat = (post.frontmatter.category || 'general').toLowerCase();
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(post);
}

const categoryOrder = ['text-tools', 'developer', 'photo-editing', 'calculators', 'docs-tools', 'zip-tools', 'seo', 'general', 'social-media'];
const totalPosts = posts.length;

const blogJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "مدونة " + siteConfig.siteName,
  "description": siteConfig.siteDescription,
  "url": siteConfig.siteUrl + "/blog/",
  "publisher": {
    "@type": "Organization",
    "name": siteConfig.siteName,
    "url": siteConfig.siteUrl
  }
});
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{`المدونة - ${siteConfig.siteName} | ${siteConfig.siteDescription}`}</title>
  <meta name="description" content={siteConfig.siteName + ' - ' + siteConfig.siteDescription}>
  <meta name="keywords" content={siteConfig.siteKeywords}>
  <link rel="canonical" href="https://toolrar.com/blog/">
  <link rel="alternate" hreflang="ar" href="https://toolrar.com/blog/">
  <link rel="alternate" hreflang="en" href="https://toolrar.com/en/blog/">
  <link rel="alternate" hreflang="x-default" href="https://toolrar.com/blog/">
  <script type="application/ld+json" set:html={blogJsonLd}></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>

  <Header activePage="blog" />

  <section class="page-header">
    <div class="header-blur1"></div>
    <div class="header-blur2"></div>
    <div class="container page-header-content">
      <div class="count-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        <span>{totalPosts} {totalPosts === 1 ? 'مقالة' : 'مقالات'}</span>
      </div>
      <h1>مدونة {siteConfig.siteName}</h1>
      <p>{siteConfig.siteDescription}</p>
    </div>
  </section>

  <section class="page-section">
    <div class="container">
      <div class="page-inner">

        {posts.length === 0 && (
          <div style="text-align:center;padding:64px 0">
            <p style="color:#9ca3af;font-size:1rem;margin-bottom:16px">لا توجد مقالات بعد. اكتب أول مقال من <a href="/admin" style="color:#6366F1;font-weight:700;">لوحة التحكم</a>.</p>
          </div>
        )}

        {categoryOrder.map(catKey => {
          const catPosts = grouped[catKey];
          if (!catPosts || catPosts.length === 0) return null;
          const color = categoryColors[catKey] || '#6366F1';
          const icon = categoryIcons[catKey] || '';
          const name = categoryNames[catKey] || catKey;
          const displayPosts = catPosts.slice(0, 6);
          return (
            <div class="cat-section">
              <div class="cat-section-header">
                <h2 class="cat-section-title">
                  <svg viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icon}></svg>
                  {name}
                </h2>
                {catPosts.length > 6 && (
                    <a href={`/blog/${catKey}.html`} class="cat-show-all">
                    عرض الكل
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                )}
              </div>
              <div class="blog-grid">
                {displayPosts.map(post => {
                  const { title, description, date, author, category } = post.frontmatter;
                  const formattedDate = date
                    ? new Date(date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' })
                    : '';
                  const authorName = author || siteConfig.siteName;
                  const catName = category || catKey;
                  return (
                    <article class="blog-card">
                      <div class="blog-card-image" style={`background:${color}22`}>
                        <svg viewBox="0 0 24 24" fill="none" stroke={color} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={icon}></svg>
                      </div>
                      <div class="blog-card-body">
                        <div class="blog-card-meta">
                          <span class="blog-card-category" style={`background:${color}22;color:${color}`}>{catName}</span>
                          <span class="blog-card-date">{formattedDate}</span>
                        </div>
                        <h3 class="blog-card-title"><a href={post.url}>{title}</a></h3>
                        <p class="blog-card-excerpt">{description || ''}</p>
                        <div class="blog-card-footer">
                          <a href={post.url} class="blog-card-link">
                            اقرأ المزيد
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                          </a>
                          <div class="blog-card-author">
                            <div class="blog-card-author-avatar">{authorName.charAt(0)}</div>
                            <span>{authorName}</span>
                          </div>
                        </div>
                      </div>
                    </article>
                  );
                })}
              </div>
            </div>
          );
        })}

      </div>
    </div>
  </section>

  <Footer />

</body>
</html>
