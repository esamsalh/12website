---
import siteConfig from '../data/site-config.json';
const s = siteConfig.social;
---
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <div class="footer-logo"><div class="logo-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg></div><span class="logo-text">{siteConfig.siteName}</span></div>
          <p class="footer-desc">{siteConfig.footerDescription}</p>
          <div class="footer-social">
            <a href={s.telegram || '#'} aria-label="Telegram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg></a>
            <a href={s.twitter || '#'} aria-label="Twitter"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg></a>
            <a href={s.instagram || '#'} aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg></a>
            <a href={s.facebook || '#'} aria-label="Facebook"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
          </div>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">روابط سريعة</h4>
          <ul>
            <li><a href="/" class="footer-link">الرئيسية</a></li>
            <li><a href="/all-tools.html" class="footer-link">جميع الأدوات</a></li>
            <li><a href="/sitemap.html" class="footer-link">التصنيفات</a></li>
            <li><a href="/blog.html" class="footer-link">المدونة</a></li>
            <li><a href="/pricing.html" class="footer-link">الأسعار</a></li>
            <li><a href="/about.html" class="footer-link">من نحن</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">الأقسام</h4>
          <ul>
            <li><a href="/text-tools/" class="footer-link">أدوات النصوص</a></li>
            <li><a href="/Developer/" class="footer-link">أدوات المطورين</a></li>
            <li><a href="/Photo-Editing/" class="footer-link">أدوات التصميم</a></li>
            <li><a href="/seo/" class="footer-link">أدوات SEO</a></li>
            <li><a href="/Social-media/" class="footer-link">السوشيال ميديا</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">تواصل معنا</h4>
          <ul>
            <li><a href="/about.html" class="footer-link">من نحن</a></li>
            <li><a href="/contact.html" class="footer-link">اتصل بنا</a></li>
            <li><a href="/pricing.html" class="footer-link">الأسعار</a></li>
            <li><a href="/privacy.html" class="footer-link">سياسة الخصوصية</a></li>
            <li><a href="/terms.html" class="footer-link">شروط الاستخدام</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-bottom-links">
          <a href="/terms.html">شروط الاستخدام</a>
          <a href="/privacy.html">سياسة الخصوصية</a>
          <a href="/sitemap.html">خريطة الموقع</a>
        </div>
        <p>{siteConfig.copyright}</p>
      </div>
    </div>
  </div>
</footer>
