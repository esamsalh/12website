---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../data/site-config.json';

export interface Props {
  title: string;
  description?: string;
  date?: string;
  author?: string;
  category?: string;
  categoryUrl?: string;
  image?: string;
  tags?: string[];
  faq?: Array<{ question: string; answer: string }>;
  canonical?: string;
}

const props = Astro.props;
const fm = props.frontmatter || props;
const title = props.title || fm?.title || '';
const description = props.description || fm?.description || '';
const date = props.date || fm?.date || '';
const author = props.author || fm?.author || 'مدونة ' + siteConfig.siteName;
const category = props.category || fm?.category || '';
const categoryUrl = props.categoryUrl || fm?.categoryUrl || '/blog';
const image = props.image || fm?.image || '';
const tags = props.tags || fm?.tags || [];
const faq = props.faq || fm?.faq || [];
const canonical = props.canonical || fm?.canonical || '';

const formattedDate = date
  ? new Date(date).toLocaleDateString('ar-SA', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const isoDate = date ? new Date(date).toISOString() : '';

const siteUrl = siteConfig.siteUrl;
const pageUrl = canonical || Astro.url.pathname;
const fullUrl = pageUrl.startsWith('http') ? pageUrl : `${siteUrl}${pageUrl}`;
const authorName = author || 'مدونة ' + siteConfig.siteName;
const catName = category || '';
const catPath = categoryUrl || '#';
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} - مدونة {siteConfig.siteName}</title>
  {description && <meta name="description" content={description}>}
  {tags && <meta name="keywords" content={tags.join(', ')}>}
  <meta name="author" content={authorName}>
  <link rel="canonical" href={fullUrl}>
  <link rel="alternate" hreflang="ar" href={fullUrl}>
  <link rel="alternate" hreflang="en" href={fullUrl.replace('toolrar.com/', 'toolrar.com/en/')}>
  <link rel="alternate" hreflang="x-default" href={fullUrl}>

  <meta property="og:title" content={title}>
  <meta property="og:description" content={description || ''}>
  {image && <meta property="og:image" content={image.startsWith('http') ? image : `${siteUrl}${image}`}>}
  <meta property="og:url" content={fullUrl}>
  <meta property="og:type" content="article">

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description || '',
    "url": fullUrl,
    "datePublished": isoDate,
    "dateModified": isoDate,
    "author": { "@type": "Person", "name": authorName },
    "publisher": { "@type": "Organization", "name": siteConfig.siteName, "url": siteUrl },
    "mainEntityOfPage": { "@type": "WebPage", "@id": fullUrl },
    ...(image ? { "image": image.startsWith('http') ? image : `${siteUrl}${image}` } : {})
  })}></script>

  {faq && faq.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faq.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })}></script>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "الرئيسية", "item": siteUrl + "/" },
      { "@type": "ListItem", "position": 2, "name": "المدونة", "item": siteUrl + "/blog/" },
      ...(catName ? [{ "@type": "ListItem", "position": 3, "name": catName, "item": siteUrl + catPath }] : []),
      { "@type": "ListItem", "position": catName ? 4 : 3, "name": title, "item": fullUrl }
    ]
  })}></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png">
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>

  <Header activePage="blog" />

  <article>
    <header class="article-header">
      <div class="container article-header-content">
        <nav class="breadcrumb">
          <a href="/">الرئيسية</a>
          <span>/</span>
          <a href="/blog.html">المدونة</a>
          {catName && <><span>/</span><a href={catPath}>{catName}</a></>}
          <span>/</span>
          <span style="color:#A5B4FC">{title}</span>
        </nav>
        <h1>{title}</h1>
        <div class="article-meta">
          {date && <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg> {formattedDate}</span>}
          <span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> {authorName}</span>
          {catName && <a href={catPath} class="category-badge">{catName}</a>}
        </div>
      </div>
    </header>

    <section class="article-section">
      <div class="container">
        <div class="article-body">
          <div class="share-buttons desktop-only">
            <span>شارك المقال:</span>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(fullUrl)}`} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="#1877F2" stroke="none"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg> فيسبوك</a>
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(fullUrl)}`} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="#1DA1F2" stroke="none"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg> تويتر</a>
            <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(fullUrl)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="#0A66C2" stroke="none"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg> لينكد إن</a>
            <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' ' + fullUrl)}`} target="_blank" rel="noopener"><svg viewBox="0 0 24 24" fill="#25D366" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg> واتساب</a>
            <a href="#" onclick="copyLink();return false;"><svg viewBox="0 0 24 24" fill="none" stroke="#6366F1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> نسخ الرابط</a>
          </div>

          <div class="share-bar-mobile" id="shareBarMobile">
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(fullUrl)}`} target="_blank" rel="noopener" aria-label="فيسبوك"><svg viewBox="0 0 24 24" fill="#1877F2" stroke="none"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(fullUrl)}`} target="_blank" rel="noopener" aria-label="تويتر"><svg viewBox="0 0 24 24" fill="#1DA1F2" stroke="none"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg></a>
            <a href={`https://api.whatsapp.com/send?text=${encodeURIComponent(title + ' ' + fullUrl)}`} target="_blank" rel="noopener" aria-label="واتساب"><svg viewBox="0 0 24 24" fill="#25D366" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg></a>
            <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(fullUrl)}&title=${encodeURIComponent(title)}`} target="_blank" rel="noopener" aria-label="لينكد إن"><svg viewBox="0 0 24 24" fill="#0A66C2" stroke="none"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg></a>
            <a href="#" onclick="copyLink();return false;" aria-label="نسخ الرابط"><svg viewBox="0 0 24 24" fill="none" stroke="#6366F1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></a>
          </div>

          <div class="article-layout">
            <div class="article-main">
              <div class="toc-inline"><nav class="toc" id="tocInline"><h3 class="toc-title">فهرس المقال</h3><ul class="toc-list" id="tocListInline"></ul></nav></div>
              <div class="article-content" id="articleContent">
                {image && (
                  <div class="featured-image-wrap">
                    <img src={image} alt={title} width="1200" height="630" loading="lazy" class="article-featured-image">
                    <span class="watermark">www.toolrar.com</span>
                  </div>
                )}
                <slot />
              </div>

              {faq && faq.length > 0 && (
                <div class="faq-inline" id="faqInline">
                  <div class="faq-sidebar">
                    <h3 class="faq-sidebar-title">الأسئلة الشائعة</h3>
                    <div class="faq-sidebar-list" id="faqListInline">
                      {faq.map((item, i) => (
                        <div class="faq-sidebar-item" data-faq-index={i}>
                          <button class="faq-sidebar-q" onclick={`toggleFaq(${i})`}>
                            {item.question}
                            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                          </button>
                          <div class="faq-sidebar-a" id={`faqAnswer${i}`}>
                            <p>{item.answer}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              )}

              <div class="author-box">
                <div class="author-avatar">{authorName.charAt(0)}</div>
                <div>
                  <h4>{authorName}</h4>
                  <p>كاتب محتوى ومتخصص في أدوات الويب والتقنية. يكتب مقالات حول تحسين الإنتاجية وأفضل الأدوات المجانية للمطورين والمسوقين.</p>
                </div>
              </div>
            </div>

            <div class="sidebar" id="sidebar">
              <nav class="toc sidebar-card"><h3 class="toc-title">فهرس المقال</h3><ul class="toc-list" id="tocListSidebar"></ul></nav>
              {faq && faq.length > 0 && (
                <div class="faq-sidebar sidebar-card">
                  <h3 class="faq-sidebar-title">الأسئلة الشائعة</h3>
                  <div class="faq-sidebar-list" id="faqListSidebar">
                    {faq.map((item, i) => (
                      <div class="faq-sidebar-item" data-faq-index={i}>
                        <button class="faq-sidebar-q" onclick={`toggleFaq(${i})`}>
                          {item.question}
                          <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                        <div class="faq-sidebar-a" id={`faqAnswerSidebar${i}`}>
                          <p>{item.answer}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </section>
  </article>

  <Footer />

  <script>
    (function() {
      function toggleFaq(index) {
        var inlineItem = document.querySelector('#faqListInline [data-faq-index="' + index + '"]');
        var sidebarItem = document.querySelector('#faqListSidebar [data-faq-index="' + index + '"]');
        if (inlineItem) inlineItem.classList.toggle('open');
        if (sidebarItem) sidebarItem.classList.toggle('open');
      }
      window.toggleFaq = toggleFaq;

      function copyLink() {
        var i = document.createElement('input');
        i.value = window.location.href;
        document.body.appendChild(i);
        i.select();
        document.execCommand('copy');
        document.body.removeChild(i);
        alert('تم نسخ الرابط بنجاح!');
      }
      window.copyLink = copyLink;

      function generateTOC() {
        var content = document.getElementById('articleContent');
        if (!content) return;
        var headings = content.querySelectorAll('h2, h3');
        var tocInline = document.getElementById('tocListInline');
        var tocSidebar = document.getElementById('tocListSidebar');
        if (!headings.length) {
          var tocNavs = document.querySelectorAll('.toc');
          tocNavs.forEach(function(el) { el.style.display = 'none'; });
          return;
        }
        var tocHtml = '';
        headings.forEach(function(h) {
          var id = h.textContent.trim().replace(/\s+/g, '-').replace(/[^\w\u0600-\u06FF-]/g, '').toLowerCase();
          h.id = id;
          var isSub = h.tagName === 'H3';
          var itemClass = isSub ? 'toc-item toc-sub' : 'toc-item';
          tocHtml += '<li class="' + itemClass + '"><a href="#' + id + '" class="toc-link">' + h.textContent.trim() + '</a></li>';
        });
        tocInline.innerHTML = tocHtml;
        tocSidebar.innerHTML = tocHtml;
      }

      function initMobileMenu() {
        var btn = document.getElementById('hamburgerBtn');
        var menu = document.getElementById('mobileMenu');
        var icon = document.getElementById('hamburgerIcon');
        if (!btn || !menu) return;
        btn.addEventListener('click', function() {
          menu.classList.toggle('open');
          if (menu.classList.contains('open')) {
            icon.innerHTML = '<line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/>';
          } else {
            icon.innerHTML = '<line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>';
          }
        });
      }

      generateTOC();
      initMobileMenu();
    })();
  </script>
</body>
</html>
